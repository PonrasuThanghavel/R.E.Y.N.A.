# Optional: Use OpenClaw Reyna Bridge (if available)
# Set to 'true' to try OpenClaw Reyna agent first, fallback to local Ollama
USE_REYNA_BRIDGE=true

# Local Ollama Configuration (fallback)
# Make sure Ollama is running: ollama serve
# Lightweight model recommended: qwen2.5-coder:0.5b (fast, low memory)
# Other models: mistral, neural-chat, dolphin-mixtral, etc.

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:0.5b
